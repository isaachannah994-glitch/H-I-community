NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ========================================
# OPCIÓN 1: PAGO PERSONALIZADO (Tu implementación)
# ========================================
# CUSTOM_PAYMENT_CONFIG.ENABLED debe ser true para activar
NEXT_PUBLIC_CUSTOM_PAYMENT_API=https://tu-api.com/payments
CUSTOM_PAYMENT_API_KEY=tu_api_key_secreto_aqui
CUSTOM_PAYMENT_WEBHOOK_SECRET=tu_webhook_secret_aqui
NEXT_PUBLIC_CUSTOM_MERCHANT_ID=tu_merchant_id

# ========================================
# OPCIÓN 2: 2CHECKOUT
# ========================================
# Para obtener credenciales: https://www.2checkout.com
# TWOCHECKOUT_CONFIG.ENABLED debe ser true para activar
NEXT_PUBLIC_2CHECKOUT_PUBLIC_KEY=tu_public_key_aqui
NEXT_PUBLIC_2CHECKOUT_ACCOUNT=tu_account_number_aqui
TWOCHECKOUT_WEBHOOK_SECRET=tu_webhook_secret_aqui

# ========================================
# OPCIÓN 3: PAYU (Colombia)
# ========================================
# Para obtener credenciales: https://developers.payulatam.com
# PAYU_CONFIG.ENABLED debe ser true para activar
NEXT_PUBLIC_PAYU_MERCHANT_ID=tu_merchant_id_aqui
NEXT_PUBLIC_PAYU_ACCOUNT_ID=tu_account_id_aqui
PAYU_API_KEY=tu_api_key_aqui
PAYU_API_LOGIN=tu_api_login_aqui
PAYU_WEBHOOK_SECRET=tu_webhook_secret_aqui

# ========================================
# OPCIÓN 4: MERCADO PAGO (Recomendado)
# ========================================
# Para obtener credenciales: https://www.mercadopago.com/developers
# MERCADO_PAGO_CONFIG.ENABLED debe ser true para activar
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=APP_USR-tu_public_key_aqui
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-tu_access_token_aqui
MERCADO_PAGO_WEBHOOK_URL=https://tu-dominio.com/api/webhooks/mercadopago
MERCADO_PAGO_NOTIFICATION_URL=https://tu-dominio.com/api/webhooks/mercadopago

